{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://powerful-balance-production-971d.up.railway.app/api/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/dashboard",
      "destination": "https://powerful-balance-production-971d.up.railway.app/dashboard.html",
      "permanent": false
    },
    {
      "source": "/dashboard.html",
      "destination": "https://powerful-balance-production-971d.up.railway.app/dashboard.html",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/dashboard.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}

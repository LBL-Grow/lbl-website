{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://powerful-balance-production-971d.up.railway.app/api/:path*"
    },
    {
      "source": "/review-approved",
      "destination": "https://powerful-balance-production-971d.up.railway.app/jake/approve"
    }
  ],
  "redirects": [
    {
      "source": "/pricing",
      "has": [{ "type": "query", "key": "plan" }],
      "destination": "/pricing",
      "permanent": true
    },
    {
      "source": "/dashboard",
      "destination": "https://powerful-balance-production-971d.up.railway.app/dashboard.html",
      "permanent": false
    },
    {
      "source": "/dashboard.html",
      "destination": "https://powerful-balance-production-971d.up.railway.app/dashboard.html",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com https://js.stripe.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https:; frame-src https://js.stripe.com; frame-ancestors 'none';" }
      ]
    },
    {
      "source": "/dashboard.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
